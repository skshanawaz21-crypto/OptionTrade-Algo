{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OptionTrader Dashboard (paper)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_dashboard.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONUTF8": "1"
      }
    },
    {
      "name": "OptionTrader Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-s",
        "tests"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "PYTHONUTF8": "1"
      }
    }
  ]
}
